<?xml version="1.0" encoding="UTF-8"?>
<!--
  data_schema.xml - 数据文件格式规范（完整树型结构）
  
  定义数据存储的完整树型结构，外部应用可按此 schema 解析紧凑格式的 data 文件。
  紧凑格式：JSON 只存 value（数组形式），按 schema 定义的顺序排列。
  
  示例紧凑格式：
  ["0700", "XHKG", "腾讯控股", "5min", 2025, 4, 66, 3, [
    ["2025-04-28", [
      ["09:30", 350.0, 351.0, 349.5, 350.5, 1000000],
      ["09:35", 350.5, 352.0, 350.0, 351.5, 1200000]
    ]],
    ["2025-04-29", [...]]
  ]]
-->
<schema version="2.0">
  
  <!-- 数据文件根节点（数组格式） -->
  <root>
    <!-- 文件级元数据（索引 0-6） -->
    <field name="code" type="string" index="0" description="标的代码" />
    <field name="exchange" type="string" index="1" description="交易所代码" />
    <field name="name" type="string" index="2" description="标的名称" />
    <field name="period" type="string" index="3" description="K线周期（如 5min）" />
    <field name="year" type="int" index="4" description="年份" />
    <field name="month" type="int" index="5" description="月份" />
    <field name="total_entry" type="int" index="6" description="总数据条数" />
    <field name="total_date" type="int" index="7" description="总天数" />
    
    <!-- 数据记录数组（索引 8） -->
    <field name="data" type="array" index="8" description="按日期分组的数据数组">
      <!-- 每条日期记录：[date, day_data] -->
      <item name="date_record" type="tuple">
        <field name="date" type="date" index="0" description="日期（YYYY-MM-DD）" />
        <field name="day_data" type="array" index="1" description="当日分时数据数组">
          <!-- 每条分时记录：[time, open, high, low, close, volume] -->
          <item name="minute_record" type="tuple">
            <field name="time" type="time" index="0" description="时间（HH:MM）" />
            <field name="open" type="float" index="1" description="开盘价" />
            <field name="high" type="float" index="2" description="最高价" />
            <field name="low" type="float" index="3" description="最低价" />
            <field name="close" type="float" index="4" description="收盘价" />
            <field name="volume" type="float" index="5" description="成交量" />
          </item>
        </field>
      </item>
    </field>
  </root>
  
  <!-- 存储路径规则 -->
  <storage>
    <path pattern="{data_dir}/{exchange}/{name}_{code}/{year}{month:02d}.json" />
    <dedup key="date" description="按 date 字段去重（日期级别）" />
  </storage>
  
</schema>
