#!/bin/bash
# DataCenter Docker 镜像发布脚本
# 支持正式发布和临时构建

set -e  # 遇到错误立即退出

# 参数解析
TMP_BUILD=false
PUSH=true

while [[ $# -gt 0 ]]; do
    case $1 in
        --tmp)
            TMP_BUILD=true
            PUSH=false
            shift
            ;;
        *)
            echo "❌ 未知参数: $1"
            echo "用法: $0 [--tmp]"
            exit 1
            ;;
    esac
done

# ========== 前置检查：确保所有变更已提交 ==========
if [ "$TMP_BUILD" = false ]; then
    # 正式发布模式：检查是否有未提交的变更
    if git rev-parse --git-dir > /dev/null 2>&1; then
        # 检查工作区是否有未提交的变更
        if [ -n "$(git status --porcelain)" ]; then
            echo "❌ 发布前必须提交所有变更！"
            echo ""
            echo "未提交的变更："
            git status --porcelain
            echo ""
            echo "请先执行以下命令提交变更："
            echo "   git add ."
            echo "   git commit -m '你的提交信息'"
            exit 1
        fi
        echo "✅ 前置检查通过：所有变更已提交"
        echo ""
    else
        echo "⚠️  非 Git 仓库，跳过变更检查"
        echo ""
    fi
else
    echo "🧪 临时构建模式：跳过变更检查"
    echo ""
fi
# ========== 前置检查结束 ==========


# 版本文件路径
VERSION_FILE="VERSION"

if [ "$TMP_BUILD" = true ]; then
    # 临时构建模式：生成随机 UUID
    if command -v uuidgen &> /dev/null; then
        UUID=$(uuidgen | tr '[:upper:]' '[:lower:]')
    else
        UUID=$(python3 -c "import uuid; print(str(uuid.uuid4()))")
    fi
    
    VERSION="tmp"
    IMAGE_TAG="tmp-${UUID}"
    
    echo "🧪 临时构建模式 (不推送到仓库)"
    echo "   UUID: ${UUID}"
    echo ""
else
    # 正式发布模式：自动版本号管理
    if [ ! -f "$VERSION_FILE" ]; then
        # 第一次发布，创建初始版本
        echo "0.1.0" > "$VERSION_FILE"
        VERSION="0.1.0"
        echo "📌 首次发布，版本号: V${VERSION}"
    else
        # 读取当前版本
        CURRENT_VERSION=$(cat "$VERSION_FILE")
        
        # 解析版本号 (major.minor.patch)
        MAJOR=$(echo "$CURRENT_VERSION" | cut -d. -f1)
        MINOR=$(echo "$CURRENT_VERSION" | cut -d. -f2)
        PATCH=$(echo "$CURRENT_VERSION" | cut -d. -f3)
        
        # 小版本号加1，补丁版本重置为0
        MINOR=$((MINOR + 1))
        PATCH=0
        
        # 生成新版本号
        VERSION="${MAJOR}.${MINOR}.${PATCH}"
        
        # 保存新版本号
        echo "$VERSION" > "$VERSION_FILE"
        echo "📌 版本号更新: V${CURRENT_VERSION} → V${VERSION}"
    fi
    
    # 获取当前 Git 提交的短哈希
    GIT_COMMIT=$(git rev-parse --short HEAD 2>/dev/null || echo "nogit")
    
    # 获取当前构建日期
    BUILD_DATE=$(date +%Y%m%d)
    
    # 生成组合标签
    IMAGE_TAG="v${VERSION}-${BUILD_DATE}-${GIT_COMMIT}"
    
    echo "🚀 正式发布模式"
    echo "   版本: V${VERSION}"
    echo "   标签: ${IMAGE_TAG}"
    echo ""
    
    # Git 操作：提交版本号变更（先提交，等构建成功后再推送）
    if git rev-parse --git-dir > /dev/null 2>&1; then
        echo "📤 Git 操作：提交版本号变更（本地）..."
        
        # 添加 VERSION 文件
        git add "$VERSION_FILE"
        
        # 提交（如果无变更则跳过）
        git commit -m "Release v${VERSION}" 2>/dev/null || echo "   ℹ️  无变更需要提交"
        
        echo ""
    else
        echo "⚠️  非 Git 仓库，跳过 Git 操作"
        echo ""
    fi
fi

# 私有仓库地址（请根据实际情况修改）
REGISTRY="192.168.31.32:5001"
IMAGE_NAME="${REGISTRY}/$(echo datacenter | tr "[:upper:]" "[:lower:]")"

echo "🔨 开始构建镜像..."
echo "   镜像: ${IMAGE_NAME}:${IMAGE_TAG}"
echo ""

# 构建镜像
docker build -t "${IMAGE_NAME}:${IMAGE_TAG}" .

if [ "$PUSH" = true ]; then
    # 正式发布：推送到仓库
    echo ""
    echo "📤 推送镜像到私有仓库..."
    
    # 同时打上纯版本号标签（方便引用）
    docker tag "${IMAGE_NAME}:${IMAGE_TAG}" "${IMAGE_NAME}:v${VERSION}"
    
    # 推送带有唯一版本号的镜像到私有仓库
    docker push "${IMAGE_NAME}:${IMAGE_TAG}"
    docker push "${IMAGE_NAME}:v${VERSION}"
    
    echo ""
    echo "✅ 镜像已成功发布: ${IMAGE_NAME}:${IMAGE_TAG}"
    echo "   简化引用: ${IMAGE_NAME}:v${VERSION}"
    
    # 镜像推送成功后，执行 Git 标签和推送操作
    if git rev-parse --git-dir > /dev/null 2>&1; then
        echo ""
        echo "📤 Git 操作：创建标签并推送到远程仓库..."
        
        # 创建 Git 标签（构建成功后）
        git tag -a "v${VERSION}" -m "Release v${VERSION}" 2>/dev/null || echo "   ℹ️  标签 v${VERSION} 已存在"
        
        # 推送到远程仓库（commit + tag）
        git push origin main 2>/dev/null || git push origin master 2>/dev/null || echo "   ⚠️  Git push 失败（可能由于网络限制）"
        git push origin "v${VERSION}" 2>/dev/null || echo "   ⚠️  Tag push 失败"
        
        echo "✅ Git 提交和标签已推送"
    fi
else
    # 临时构建：仅本地构建，不推送
    echo ""
    echo "✅ 临时镜像已构建（未推送）: ${IMAGE_NAME}:${IMAGE_TAG}"
    echo "   使用方式: docker run -it ${IMAGE_NAME}:${IMAGE_TAG} bash"
fi
