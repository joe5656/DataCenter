{
    "name": "stock_5min",
    "version": "v1",
    "data_schema": {
        "date": "string",
        "code": "string",
        "market": "string",
        "name": "string",
        "time": "string",
        "open": "double",
        "close": "double",
        "high": "double",
        "low": "double",
        "volume": "int64"
    },
    "storage_rule": "{schema.name}/{schema.date}.parquet"
}