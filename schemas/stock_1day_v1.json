{
    "name": "stock_1day",
    "version": "v1",
    "data_schema": {
        "Year": "string",
        "Month": "string",
        "date": "string",
        "market": "string",
        "stock_code": "string",
        "stock_name": "string",
        "open": "double",
        "close": "double",
        "high": "double",
        "low": "double",
        "volume": "int64"
    },
    "storage_rule": "{schema.name}/{schema.Year}/{schema.Month}.parquet"
}